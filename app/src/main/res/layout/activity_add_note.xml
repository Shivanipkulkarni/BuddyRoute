<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1D9E75"
            android:padding="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                android:tint="#FFFFFF"
                android:contentDescription="Back"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Note"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginStart="12dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Note text -->
            <TextView
                android:text="What's happening? ✍️"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/etNoteText"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:hint="Write something about this moment..."
                android:padding="12dp"
                android:background="@drawable/input_background"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"
                android:inputType="textMultiLine|textCapSentences"
                android:gravity="top"/>

            <!-- Mood selector -->
            <TextView
                android:text="How are you feeling? 😊"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/moodHappy"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="😄"
                    android:textSize="24sp"
                    android:gravity="center"
                    android:background="@drawable/mood_bg_unselected"
                    android:layout_marginEnd="6dp"
                    android:padding="4dp"/>

                <TextView
                    android:id="@+id/moodAmazed"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="🤩"
                    android:textSize="24sp"
                    android:gravity="center"
                    android:background="@drawable/mood_bg_unselected"
                    android:layout_marginEnd="6dp"
                    android:padding="4dp"/>

                <TextView
                    android:id="@+id/moodTired"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="😴"
                    android:textSize="24sp"
                    android:gravity="center"
                    android:background="@drawable/mood_bg_unselected"
                    android:layout_marginEnd="6dp"
                    android:padding="4dp"/>

                <TextView
                    android:id="@+id/moodHungry"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="🍔"
                    android:textSize="24sp"
                    android:gravity="center"
                    android:background="@drawable/mood_bg_unselected"
                    android:layout_marginEnd="6dp"
                    android:padding="4dp"/>

                <TextView
                    android:id="@+id/moodPeaceful"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="😌"
                    android:textSize="24sp"
                    android:gravity="center"
                    android:background="@drawable/mood_bg_unselected"
                    android:padding="4dp"/>

            </LinearLayout>

            <!-- Photo attach -->
            <TextView
                android:text="Attach a Photo (optional) 📷"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnPickPhoto"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Choose from Gallery"
                android:backgroundTint="#EEEEEE"
                android:textColor="#333333"
                android:layout_marginTop="8dp"/>

            <ImageView
                android:id="@+id/ivPhotoPreview"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_background"/>

            <!-- Save button -->
            <Button
                android:id="@+id/btnSaveNote"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="💾 Save Note"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1D9E75"
                android:layout_marginTop="24dp"/>
            <Button
                android:id="@+id/btnAddVoice"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="🎤 Add Voice Note"
                android:backgroundTint="#EEEEEE"
                android:textColor="#333333"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"/>


        </LinearLayout>
    </LinearLayout>
</ScrollView>