<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── HERO HEADER ── -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/heroLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="240dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:background="@drawable/hero_background">

                <!-- Decorative circles -->
                <View
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:background="@drawable/circle_shape"
                    android:alpha="0.08"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="-50dp"
                    android:layout_marginEnd="-50dp"/>

                <View
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/circle_shape"
                    android:alpha="0.06"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_marginBottom="-30dp"
                    android:layout_marginStart="-30dp"/>

                <!-- Top row — logo + help + SOS -->
                <LinearLayout
                    android:id="@+id/topRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    app:layout_constraintTop_toTopOf="parent">

                    <!-- App icon + name -->
                    <TextView
                        android:text="🗺️"
                        android:textSize="24sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="BuddyRoute"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginStart="8dp"/>

                    <!-- Help button -->
                    <TextView
                        android:id="@+id/btnHelp"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="?"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:background="@drawable/streak_badge_bg"
                        android:layout_marginEnd="8dp"/>

                    <!-- SOS button — always visible -->
                    <TextView
                        android:id="@+id/btnSOS"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="🆘 SOS"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:background="@drawable/sos_button_bg"/>

                </LinearLayout>

                <!-- Greeting + tagline -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    app:layout_constraintTop_toBottomOf="@id/topRow"
                    app:layout_constraintBottom_toTopOf="@id/statsCard">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good morning! ☀️"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Where are you exploring today?"
                        android:textSize="13sp"
                        android:textColor="#CCFFFFFF"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

                <!-- Stats card overlapping hero -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/statsCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="8dp"
                    app:layout_constraintTop_toBottomOf="@id/topRow"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintVertical_bias="1.0"
                    android:layout_marginBottom="-40dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp"
                        android:visibility="gone"
                        android:id="@+id/statsStrip">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvTotalTrips"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Trips"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#1D9E75"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Trips"
                                android:textSize="11sp"
                                android:textColor="#888888"/>

                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:background="#EEEEEE"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvTotalDistance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="km"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#1D9E75"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="km travelled"
                                android:textSize="11sp"
                                android:textColor="#888888"/>

                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:background="#EEEEEE"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvTotalNotes"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Notes"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#1D9E75"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Moments"
                                android:textSize="11sp"
                                android:textColor="#888888"/>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Empty state inside card -->
                    <LinearLayout
                        android:id="@+id/emptyStatsLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No trips yet"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#333333"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap ➕ below to start your first adventure!"
                            android:textSize="12sp"
                            android:textColor="#888888"
                            android:gravity="center"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Spacer for card overlap -->
            <View
                android:layout_width="match_parent"
                android:layout_height="60dp"/>

            <!-- ── STREAK BANNER ── -->
            <LinearLayout
                android:id="@+id/streakBadge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFF8E7"
                android:padding="12dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:text="🔥"
                        android:textSize="20sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/tvStreakCount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#BA7517"
                        android:layout_marginStart="8dp"/>

                    <TextView
                        android:id="@+id/tvStreakNext"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="#BBBBBB"/>

                </LinearLayout>

                <!-- Progress bar -->
                <ProgressBar
                    android:id="@+id/streakProgress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progressTint="#BA7517"
                    android:progressBackgroundTint="#EEEEEE"
                    android:max="100"/>

            </LinearLayout>


            <!-- ── SECTION HEADER ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="My Trips"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"/>

                <!-- Compare button -->
                <TextView
                    android:id="@+id/btnCompareText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡ Compare"
                    android:textSize="13sp"
                    android:textColor="#534AB7"
                    android:textStyle="bold"
                    android:padding="6dp"/>
                <TextView
                    android:id="@+id/btnScratchMap"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🗺️ Map"
                    android:textSize="13sp"
                    android:textColor="#1B4332"
                    android:textStyle="bold"
                    android:padding="6dp"
                    android:layout_marginStart="4dp"/>

            </LinearLayout>

            <!-- ── TRIPS LIST ── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/tripsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="140dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"/>

            <!-- ── EMPTY STATE ── -->
            <LinearLayout
                android:id="@+id/emptyStateLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="40dp"
                android:visibility="gone">

                <TextView
                    android:text="🗺️"
                    android:textSize="64sp"
                    android:gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="No trips yet!"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"/>

                <TextView
                    android:text="Your adventures will appear here.\nTap ➕ to start your first trip!"
                    android:textSize="14sp"
                    android:textColor="#888888"
                    android:gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ── FAB ── -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabNewTrip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="72dp"
        android:contentDescription="Start new trip"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#1D9E75"
        app:tint="#FFFFFF"/>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="#1D9E75"
        app:itemTextColor="#1D9E75"
        app:labelVisibilityMode="labeled"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>