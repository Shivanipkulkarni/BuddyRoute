<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Green background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1D9E75"/>
        </shape>
    </item>

    <!-- Subtle pattern — overlapping circles for a map-like feel -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#0A000000"/>
            <size android:width="400dp" android:height="400dp"/>
        </shape>
    </item>

    <!-- App icon centered -->
    <item
        android:drawable="@mipmap/ic_launcher_round"
        android:gravity="center"
        android:width="96dp"
        android:height="96dp"/>

</layer-list>